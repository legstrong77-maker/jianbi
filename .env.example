# 剪筆 環境變數範例
#
# 本機開發：複製這個檔案為 .env.local，填入你自己的值。
# .env.local 已在 .gitignore 裡，不會被 git 追蹤。
#
# Vercel 部署：到 Vercel Dashboard → Settings → Environment Variables
# 逐項貼入。**絕對不要**把真實 key 寫進這個範例檔並推上 GitHub。

# ─────────────────────────────────────────
# Demo 模式（作品集展示用）
# ─────────────────────────────────────────
# 啟用後：訪客不用自帶 Key，直接用你的 Gemini 額度。
# 預設未啟用（NEXT_PUBLIC_DEMO_MODE 沒設或為 0 時，需要訪客自帶 Key）。
NEXT_PUBLIC_DEMO_MODE=1

# 你的 Gemini API Key（到 https://aistudio.google.com/apikey 拿）
# 只會在伺服器端使用，不會暴露給瀏覽器。
GEMINI_API_KEY=

# Demo 模式的每 IP 限額（防止有人狂刷你額度）
# 預設：每小時 10 次、每日 30 次
DEMO_LIMIT_PER_HOUR=10
DEMO_LIMIT_PER_DAY=30

# ─────────────────────────────────────────
# Site URL（選配，用於 OG image 的絕對路徑）
# ─────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://jianbi.vercel.app
